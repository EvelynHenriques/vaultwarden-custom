/* EBVault olive-green theme (loaded via /css/vaultwarden.css). */

$olive-50: #f4f6ef;
$olive-100: #e9eedc;
$olive-200: #d3ddb8;
$olive-300: #b5c695;
$olive-400: #8ba25f;
$olive-500: #6b7e3a;
$olive-600: #556b2f;
$olive-700: #445526;
$olive-800: #36421e;
$olive-900: #2a3518;
$olive-950: #1a2110;
$text-light: #f4f6ef;
$text-light-muted: #d3ddb8;
$text-dark: #2a3518;
$text-dark-muted: #556b2f;

@mixin olive-brand-vars {
  --color-primary-100: 237 242 227;
  --color-primary-200: 214 224 194;
  --color-primary-300: 181 198 149;
  --color-primary-400: 139 162 95;
  --color-primary-500: 107 126 58;
  --color-primary-600: 85 107 47;
  --color-primary-700: 68 85 38;
  --color-primary-800: 54 68 30;
  --color-primary-900: 42 53 24;

  --color-brand-050: #{$olive-50};
  --color-brand-100: #{$olive-100};
  --color-brand-200: #{$olive-200};
  --color-brand-300: #{$olive-300};
  --color-brand-400: #{$olive-400};
  --color-brand-500: #{$olive-500};
  --color-brand-600: #{$olive-600};
  --color-brand-700: #{$olive-700};
  --color-brand-800: #{$olive-800};
  --color-brand-900: #{$olive-900};
  --color-brand-950: #{$olive-950};
  --color-brand-950-rgb: 26, 33, 16;

  --color-marketing-logo: 85 107 47;
  --color-bw-blue: 85 107 47;

  --color-bg-brand: var(--color-brand-600);
  --color-bg-brand-strong: var(--color-brand-700);
  --color-bg-brand-stronger: var(--color-brand-800);
  --color-bg-brand-soft: var(--color-brand-100);
  --color-bg-brand-medium: var(--color-brand-200);
  --color-bg-brand-softer: var(--color-brand-050);

  --color-fg-brand: var(--color-brand-600);
  --color-fg-brand-strong: var(--color-brand-800);
  --color-fg-brand-soft: var(--color-brand-300);

  --color-border-brand: var(--color-brand-600);
  --color-border-brand-soft: var(--color-brand-300);
  --color-border-brand-strong: var(--color-brand-800);

  --color-nav-bg-primary: var(--color-brand-800);
  --color-nav-bg-primary-strong: var(--color-brand-900);
  --color-nav-border-primary: var(--color-brand-700);

  --color-bg-avatar-brand: var(--color-brand-600);
  --color-bg-avatar-brand-hover: var(--color-brand-700);
}

/* ========== LIGHT THEME ========== */
:root,
.theme_light {
  @include olive-brand-vars;

  --color-background: 244 246 239;
  --color-background-alt: 233 238 220;
  --color-background-alt2: 214 224 194;
  --color-background-alt3: 181 198 149;
  --color-background-alt4: 139 162 95;

  --color-gray-050: #{$olive-50};
  --color-gray-100: #{$olive-100};
  --color-gray-200: #{$olive-200};
  --color-gray-300: #{$olive-300};
  --color-gray-400: #{$olive-500};
  --color-gray-500: #{$olive-600};
  --color-gray-600: #{$olive-700};
  --color-gray-700: #{$olive-800};
  --color-gray-800: #{$olive-900};
  --color-gray-900: #{$olive-900};
  --color-gray-950: #{$olive-950};

  --color-text-main: 42 53 24;
  --color-text-muted: 85 107 47;
  --color-text-contrast: 244 246 239;

  --color-fg-heading: #{$text-dark};
  --color-fg-body: #{$text-dark};
  --color-fg-body-subtle: #{$text-dark-muted};
  --color-fg-disabled: #{$olive-500};
  --color-fg-contrast: #{$text-light};

  --color-bg-primary: #{$olive-50};
  --color-bg-secondary: #{$olive-100};
  --color-bg-tertiary: #{$olive-50};
  --color-bg-quaternary: #{$olive-200};
  --color-bg-dark: #{$olive-800};

  --color-border-base: #{$olive-300};
  --color-border-strong: #{$olive-500};
  --color-border-muted: #{$olive-200};

  --color-nav-bg-secondary: #{$olive-100};
  --color-nav-bg-secondary-strong: #{$olive-200};
  --color-nav-border-secondary: #{$olive-300};

  --color-hover-default: rgb(68 85 38 / 0.08);
  --tw-ring-offset-color: #{$olive-50};

  color: #{$text-dark};
}

/* ========== DARK THEME ========== */
.theme_dark {
  @include olive-brand-vars;

  --color-background: 26 33 16;
  --color-background-alt: 34 42 22;
  --color-background-alt2: 42 53 24;
  --color-background-alt3: 54 68 30;
  --color-background-alt4: 26 33 16;

  --color-primary-600: 139 162 95;
  --color-primary-700: 181 198 149;

  --color-gray-050: #{$olive-100};
  --color-gray-100: #{$olive-200};
  --color-gray-200: #{$olive-300};
  --color-gray-300: #{$olive-400};
  --color-gray-400: #{$olive-500};
  --color-gray-500: #{$olive-600};
  --color-gray-600: #{$olive-700};
  --color-gray-700: #{$olive-800};
  --color-gray-800: #{$olive-900};
  --color-gray-900: #{$olive-900};
  --color-gray-950: #{$olive-950};
  --color-gray-950-rgb: 26, 33, 16;

  --color-text-main: 233 238 220;
  --color-text-muted: 181 198 149;
  --color-text-contrast: 26 33 16;

  --color-fg-heading: #{$text-light};
  --color-fg-body: #{$text-light};
  --color-fg-body-subtle: #{$text-light-muted};
  --color-fg-disabled: #{$olive-500};
  --color-fg-contrast: #{$text-dark};

  --color-fg-brand: var(--color-brand-300);
  --color-fg-brand-strong: var(--color-brand-200);

  --color-bg-primary: #{$olive-950};
  --color-bg-secondary: #{$olive-900};
  --color-bg-tertiary: #{$olive-950};
  --color-bg-quaternary: #{$olive-800};
  --color-bg-dark: #{$olive-900};

  --color-border-base: #{$olive-800};
  --color-border-strong: #{$olive-700};
  --color-border-muted: #{$olive-900};

  --color-nav-bg-secondary: #{$olive-900};
  --color-nav-bg-secondary-strong: #{$olive-800};
  --color-nav-border-secondary: #{$olive-800};

  --color-bg-brand: var(--color-brand-500);
  --color-bg-brand-strong: var(--color-brand-400);

  --color-hover-default: rgb(181 198 149 / 0.1);
  --tw-ring-offset-color: #{$olive-950};

  color: #{$text-light};
}

/* Readable text — dark theme */
.theme_dark [bitTypography],
.theme_dark bit-label,
.theme_dark label,
.theme_dark p,
.theme_dark span,
.theme_dark td,
.theme_dark th,
.theme_dark li,
.theme_dark h1,
.theme_dark h2,
.theme_dark h3,
.theme_dark h4,
.theme_dark bit-form-field,
.theme_dark bit-section,
.theme_dark bit-callout,
.theme_dark .tw-text-fg-body,
.theme_dark .tw-text-fg-heading,
.theme_dark .tw-text-fg-body-subtle,
.theme_dark .tw-text-secondary-500,
.theme_dark .tw-text-secondary-600,
.theme_dark .tw-text-secondary-700,
.theme_dark .tw-text-muted,
.theme_dark .text-muted {
  color: #{$text-light};
}

.theme_dark .tw-text-fg-body-subtle,
.theme_dark .tw-text-fg-disabled,
.theme_dark small,
.theme_dark [bitTypography="helper"] {
  color: #{$text-light-muted};
}

/* Readable text — light theme */
.theme_light [bitTypography],
.theme_light bit-label,
.theme_light label,
.theme_light p,
.theme_light span,
.theme_light td,
.theme_light th,
.theme_light li,
.theme_light h1,
.theme_light h2,
.theme_light h3,
.theme_light h4,
.theme_light bit-form-field,
.theme_light bit-section,
.theme_light .tw-text-fg-body,
.theme_light .tw-text-fg-heading {
  color: #{$text-dark};
}

.theme_light .tw-text-fg-body-subtle,
.theme_light .tw-text-fg-disabled,
.theme_light small {
  color: #{$text-dark-muted};
}

/* Primary actions */
button[buttonType="primary"],
button[buttontype="primary"],
.tw-bg-bg-brand,
.tw-bg-bg-brand-strong,
.tw-bg-primary-600 {
  background-color: #{$olive-600} !important;
  border-color: #{$olive-600} !important;
  color: #{$text-light} !important;
}

button[buttonType="primary"]:hover,
button[buttontype="primary"]:hover,
.tw-bg-bg-brand:hover {
  background-color: #{$olive-700} !important;
  border-color: #{$olive-700} !important;
}

.theme_light button[buttonType="secondary"],
.theme_light button[buttontype="secondary"] {
  background-color: #{$olive-100} !important;
  border-color: #{$olive-400} !important;
  color: #{$text-dark} !important;
}

.theme_dark button[buttonType="secondary"],
.theme_dark button[buttontype="secondary"] {
  background-color: #{$olive-900} !important;
  border-color: #{$olive-700} !important;
  color: #{$text-light} !important;
}

/* Links & accents */
.tw-text-primary-600,
.tw-text-fg-brand,
.tw-text-fg-brand-strong,
a.tw-text-primary-600,
bit-link.tw-text-primary-600,
a[routerlink="/signup"] {
  color: #{$olive-400} !important;
}

.theme_light .tw-text-primary-600,
.theme_light .tw-text-fg-brand,
.theme_light a.tw-text-primary-600 {
  color: #{$olive-700} !important;
}

/* Dropdowns / selects (fix blue highlight) */
.ng-dropdown-panel,
.ng-dropdown-panel .ng-dropdown-panel-items,
bit-select-panel,
[role="listbox"] {
  background-color: #{$olive-900} !important;
}

.theme_light .ng-dropdown-panel,
.theme_light bit-select-panel,
.theme_light [role="listbox"] {
  background-color: #{$olive-100} !important;
}

.ng-option.ng-option-selected,
.ng-option.ng-option-marked,
.ng-option.ng-option-selected.ng-option-marked,
[role="option"][aria-selected="true"],
.bit-select-option-selected {
  background-color: #{$olive-600} !important;
  color: #{$text-light} !important;
}

.ng-option,
[role="option"] {
  color: #{$text-light} !important;
}

.theme_light .ng-option,
.theme_light [role="option"] {
  color: #{$text-dark} !important;
}

/* Nav active item */
bit-nav-item a[aria-current="page"],
bit-nav-item a.active,
bit-nav-item a.tw-bg-primary-600 {
  background-color: #{$olive-700} !important;
  color: #{$text-light} !important;
}

/* Avatars */
bit-avatar,
.tw-bg-avatar-brand,
[class*="tw-bg-avatar-brand"] {
  background-color: #{$olive-600} !important;
  color: #{$text-light} !important;
}

/* Logo wordmark -> EBVault */
bit-nav-logo bit-svg svg,
auth-password-manager-logo svg,
app-password-manager-logo svg,
img.new-logo-themed,
.new-logo-themed img {
  opacity: 0 !important;
  width: 0 !important;
  height: 0 !important;
  overflow: hidden !important;
  position: absolute !important;
}

bit-nav-logo,
auth-password-manager-logo,
app-password-manager-logo {
  position: relative;
  min-height: 2rem;
}

bit-nav-logo::after,
auth-password-manager-logo::after,
app-password-manager-logo::after {
  content: "EBVault";
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 2rem;
}

.theme_dark auth-password-manager-logo::after {
  color: #{$text-light};
}

/* Side nav: always light text on olive-green background (both themes) */
bit-side-nav span,
bit-side-nav p,
bit-side-nav a,
bit-side-nav bit-nav-item,
bit-side-nav bit-nav-group,
bit-side-nav navigation-product-switcher,
bit-side-nav navigation-product-switcher a,
bit-side-nav navigation-product-switcher span,
.theme_light bit-side-nav span,
.theme_light bit-side-nav p,
.theme_light bit-side-nav a,
.theme_light bit-side-nav bit-nav-item,
.theme_light bit-side-nav bit-nav-group,
.theme_light app-side-nav bit-side-nav span,
.theme_light app-side-nav bit-side-nav a {
  color: #{$text-light} !important;
}

bit-side-nav .tw-text-xs,
bit-side-nav .tw-text-alt2,
bit-side-nav .\!tw-text-alt2,
bit-side-nav .tw-text-fg-nav,
bit-side-nav .tw-text-fg-body-subtle {
  color: #{$text-light-muted} !important;
}

bit-side-nav bit-nav-logo::after,
.theme_light bit-side-nav bit-nav-logo::after {
  color: #{$text-light} !important;
}

.theme_dark bit-form-field label,
.theme_dark .tw-text-primary-700,
.theme_dark .tw-text-primary-800,
.theme_dark .tw-text-blue-600,
.theme_dark .tw-text-blue-700 {
  color: #{$text-light} !important;
}

.theme_light bit-form-field label {
  color: #{$text-dark} !important;
}

.theme_dark th,
.theme_dark thead td,
.theme_dark .tw-text-secondary-700,
.theme_dark .tw-text-secondary-800 {
  color: #{$text-light-muted} !important;
}

.theme_dark bit-empty-state,
.theme_dark bit-empty-state p,
.theme_dark bit-empty-state span {
  color: #{$text-light} !important;
}

.theme_dark bit-callout,
.theme_dark bit-section-header {
  color: #{$text-light};
}

.theme_light bit-empty-state p {
  color: #{$text-dark-muted} !important;
}

/* Inputs */
.theme_dark input,
.theme_dark select,
.theme_dark textarea,
.theme_dark bit-select,
.theme_dark .ng-select-container {
  color: #{$text-light} !important;
  background-color: #{$olive-900} !important;
  border-color: #{$olive-700} !important;
}

.theme_light input,
.theme_light select,
.theme_light textarea,
.theme_light bit-select,
.theme_light .ng-select-container {
  color: #{$text-dark} !important;
  background-color: #{$olive-50} !important;
  border-color: #{$olive-400} !important;
}

