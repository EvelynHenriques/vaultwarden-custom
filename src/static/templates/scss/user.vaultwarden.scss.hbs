/* Olive green theme for the web vault (injected via /css/vaultwarden.css). */

/* Shared olive palette */
$olive-50: #f4f6ef;
$olive-100: #e9eedc;
$olive-200: #d3ddb8;
$olive-300: #b5c695;
$olive-400: #8ba25f;
$olive-500: #6b7e3a;
$olive-600: #556b2f;
$olive-700: #445526;
$olive-800: #36421e;
$olive-900: #2a3518;
$olive-950: #1a2110;

:root,
.theme_light {
  /* Legacy RGB tokens (Tailwind primary utilities) */
  --color-primary-100: 237 242 227;
  --color-primary-200: 214 224 194;
  --color-primary-300: 181 198 149;
  --color-primary-400: 139 162 95;
  --color-primary-500: 107 126 58;
  --color-primary-600: 85 107 47;
  --color-primary-700: 68 85 38;
  --color-primary-800: 54 68 30;
  --color-primary-900: 42 53 24;

  /* Login / marketing backgrounds (replace default blue gradient) */
  --color-background-alt2: 85 107 47;
  --color-background-alt3: 68 85 38;
  --color-background-alt4: 42 53 24;

  --color-marketing-logo: 85 107 47;
  --color-bw-blue: 85 107 47;
  --color-hover-default: rgb(68 85 38 / 0.1);

  --color-illustration-outline: 42 53 24;
  --color-illustration-bg-primary: 237 242 227;
  --color-illustration-bg-secondary: 181 198 149;
  --color-illustration-logo: 85 107 47;

  /* New design-system brand palette */
  --color-brand-050: #{$olive-50};
  --color-brand-100: #{$olive-100};
  --color-brand-200: #{$olive-200};
  --color-brand-300: #{$olive-300};
  --color-brand-400: #{$olive-400};
  --color-brand-500: #{$olive-500};
  --color-brand-600: #{$olive-600};
  --color-brand-700: #{$olive-700};
  --color-brand-800: #{$olive-800};
  --color-brand-900: #{$olive-900};
  --color-brand-950: #{$olive-950};
  --color-brand-950-rgb: 26, 33, 16;

  /* Semantic brand tokens */
  --color-fg-brand-soft: var(--color-brand-200);
  --color-fg-brand: var(--color-brand-700);
  --color-fg-brand-strong: var(--color-brand-800);

  --color-bg-brand-softer: var(--color-brand-050);
  --color-bg-brand-soft: var(--color-brand-100);
  --color-bg-brand-medium: var(--color-brand-200);
  --color-bg-brand: var(--color-brand-700);
  --color-bg-brand-strong: var(--color-brand-800);
  --color-bg-brand-stronger: var(--color-brand-900);

  --color-border-brand-soft: var(--color-brand-200);
  --color-border-brand: var(--color-brand-700);
  --color-border-brand-strong: var(--color-brand-900);

  /* Sidebar / navigation */
  --color-nav-bg-primary: var(--color-brand-800);
  --color-nav-bg-primary-strong: var(--color-brand-900);
  --color-nav-border-primary: var(--color-brand-700);
  --color-nav-bg-secondary-hover: rgba(var(--color-brand-950-rgb), 0.1);
  --color-nav-bg-secondary-hover-strong: rgba(var(--color-brand-950-rgb), 0.25);

  --color-bg-avatar-brand: var(--color-brand-700);
  --color-bg-avatar-brand-hover: var(--color-brand-800);
}

.theme_dark {
  --color-primary-100: 54 68 30;
  --color-primary-300: 85 107 47;
  --color-primary-600: 139 162 95;
  --color-primary-700: 181 198 149;

  --color-background-alt2: 54 68 30;
  --color-background-alt3: 68 85 38;
  --color-background-alt4: 26 33 16;

  --color-marketing-logo: 139 162 95;
  --color-bw-blue: 139 162 95;
  --color-hover-default: rgb(181 198 149 / 0.12);

  --color-illustration-outline: 181 198 149;
  --color-illustration-bg-primary: 42 53 24;
  --color-illustration-bg-secondary: 68 85 38;
  --color-illustration-logo: 139 162 95;

  --color-brand-050: #1a2110;
  --color-brand-100: #2a3518;
  --color-brand-200: #36421e;
  --color-brand-300: #445526;
  --color-brand-400: #556b2f;
  --color-brand-500: #6b7e3a;
  --color-brand-600: #8ba25f;
  --color-brand-700: #b5c695;
  --color-brand-800: #d3ddb8;
  --color-brand-900: #e9eedc;
  --color-brand-950: #f4f6ef;
  --color-brand-950-rgb: 244, 246, 239;

  --color-nav-bg-primary: var(--color-brand-300);
  --color-nav-bg-primary-strong: var(--color-brand-400);
  --color-nav-border-primary: var(--color-brand-500);
}

/* Utility-class fallbacks for components that hardcode Tailwind primary classes */
.tw-bg-primary-600,
.tw-bg-primary-500,
.tw-bg-primary-700,
.tw-bg-brand-700,
.tw-bg-brand-800 {
  background-color: #{$olive-600} !important;
}

.tw-bg-primary-600:hover,
.tw-bg-primary-500:hover,
.tw-bg-primary-700:hover,
.tw-bg-brand-700:hover,
.tw-bg-brand-800:hover {
  background-color: #{$olive-700} !important;
}

.tw-text-primary-600,
.tw-text-primary-500,
.tw-text-primary-700,
.tw-text-brand-700,
a.tw-text-primary-600,
bit-link.tw-text-primary-600 {
  color: #{$olive-600} !important;
}

.tw-text-primary-600:hover,
a.tw-text-primary-600:hover {
  color: #{$olive-700} !important;
}

.tw-border-primary-600,
.tw-border-primary-500,
.tw-border-brand-700 {
  border-color: #{$olive-600} !important;
}

.tw-ring-primary-600,
.tw-ring-brand-700 {
  --tw-ring-color: #{$olive-600} !important;
}

button[buttonType="primary"],
button[buttontype="primary"],
button[buttonType="primary"].primary,
button[buttontype="primary"].primary {
  background-color: #{$olive-600} !important;
  border-color: #{$olive-600} !important;
}

button[buttonType="primary"]:hover,
button[buttontype="primary"]:hover {
  background-color: #{$olive-700} !important;
  border-color: #{$olive-700} !important;
}

bit-nav-item a.tw-bg-primary-600,
bit-nav-item a[class*="tw-bg-primary"],
bit-nav-item a[class*="tw-bg-brand"] {
  background-color: #{$olive-600} !important;
}

bit-nav-item a.tw-text-primary-600,
bit-nav-item a[class*="tw-text-primary"] {
  color: #{$olive-200} !important;
}

/* Auth layout / login panel accents */
.layout_frontend,
app-login,
app-unlock,
app-two-factor-auth {
  --color-primary-600: 85 107 47;
  --color-brand-700: #{$olive-700};
  --color-bg-brand: #{$olive-700};
}

/* 2025+ buttons use semantic Tailwind utilities (tw-bg-bg-brand, etc.) */
.tw-bg-bg-brand,
.tw-bg-bg-brand-strong,
.tw-bg-bg-brand-stronger,
.tw-bg-brand-700,
.tw-bg-brand-800 {
  background-color: #{$olive-600} !important;
}

.tw-bg-bg-brand:hover,
.tw-bg-bg-brand-strong:hover,
.tw-bg-brand-700:hover,
.tw-bg-brand-800:hover {
  background-color: #{$olive-700} !important;
}

.tw-text-fg-brand,
.tw-text-fg-brand-strong,
.tw-text-brand-700 {
  color: #{$olive-600} !important;
}

.tw-border-border-brand,
.tw-border-brand-700 {
  border-color: #{$olive-600} !important;
}
