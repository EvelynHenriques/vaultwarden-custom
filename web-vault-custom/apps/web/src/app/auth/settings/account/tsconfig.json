{
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "composite": true
  },
  "include": [
    "./*.ts",
    "./*.d.ts",
    "../../../layouts/header/header.module.ts",
    "../../../shared/index.ts",
    "../../../vault/settings/purge-vault.component.ts",
    "../../../../../../../types/**/*.d.ts"
  ]
}
