{
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"]
  },
  "include": ["apps/**/*.ts", "apps/**/*.d.ts", "types/**/*.d.ts"],
  "exclude": [
    "apps/web/src/app/auth/settings/two-factor/**",
    "apps/web/src/app/vault/guards/**"
  ]
}
